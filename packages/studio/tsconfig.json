{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "verbatimModuleSyntax": true,
    "noEmit": true,
    "paths": {
      "@modelflow/core": ["../core/src/index.ts"],
      "@modelflow/std": ["../std/src/index.ts"]
    }
  },
  "include": ["src"]
}
